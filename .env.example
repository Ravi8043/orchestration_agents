NODE_ENV=development
PORT=5000
LOG_LEVEL=info
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sentiment_db"
REDIS_URL=redis://localhost:6379
ANALYSIS_QUEUE_NAME=analysis-runs
ANALYSIS_RETRY_ATTEMPTS=2
ANALYSIS_BACKOFF_MS=30000
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash
OPENAI_API_KEY=replace-me
GOOGLE_API_KEY=replace-me
FINNHUB_API_KEY=replace-me
TAVILY_API_KEY=replace-me
